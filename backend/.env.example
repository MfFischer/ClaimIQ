# ─── ClaimIQ Backend Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Development: SQLite (no setup, never pauses)
DATABASE_URL=sqlite+aiosqlite:///./claimiq.db

# Production: uncomment and set Neon or Railway Postgres
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/claimiq

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# Production Cloudflare R2 (uncomment when deploying)
# STORAGE_BACKEND=r2
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=claimiq-uploads
# R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Provider strategy:
# - Primary provider is tried first.
# - If primary fails, backend automatically falls back to the other provider
#   when configured.
# - If neither provider key is set, MOCK MODE is used.
LLM_PRIMARY_PROVIDER=gemini

# Gemini (primary by default)
# Get free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenRouter (fallback by default)
# Get free key from: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── OCR ──────────────────────────────────────────────────────────────────────
# Install Tesseract:
#   Windows: https://github.com/UB-Mannheim/tesseract/wiki
#            Default path: C:/Program Files/Tesseract-OCR/tesseract.exe
#   Linux:   sudo apt install tesseract-ocr tesseract-ocr-deu tesseract-ocr-eng
#   Mac:     brew install tesseract tesseract-lang
#
# After install, set the path below (Windows users especially):
TESSERACT_CMD=tesseract
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

OCR_CONFIDENCE_THRESHOLD=0.80

# ── Azure AI Vision (OCR fallback) ───────────────────────────────────────────
# EU data residency · 5,000 free transactions/month (F0 tier)
#
# Setup:
#   1. portal.azure.com → Create resource → "Computer Vision" (or "Azure AI Vision")
#   2. Select region: Germany West Central (recommended for GDPR / EU data residency)
#   3. Pricing tier: F0 (Free) — 5,000 calls/month
#   4. After creation → Keys and Endpoint → copy KEY 1 and Endpoint below
#
AZURE_VISION_ENDPOINT=
AZURE_VISION_API_KEY=
AZURE_VISION_MONTHLY_LIMIT=5000

# ── File Limits ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,tiff,tif
SESSION_TTL_HOURS=24
IDEMPOTENCY_TTL_HOURS=24

# Worker + hardening
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=1.5
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BACKOFF_SECONDS=5

# RBAC/Audit/Telemetry
AUDIT_RETENTION_DAYS=90
TELEMETRY_LOOKBACK_HOURS=24

# Cost estimation per processed claim (dashboard telemetry)
LLM_GEMINI_ESTIMATED_COST_USD=0.004
LLM_OPENROUTER_ESTIMATED_COST_USD=0.006
LLM_FALLBACK_COST_MULTIPLIER=1.7
